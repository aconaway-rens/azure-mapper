# Azure Mapper - Configuration

# Flask
FLASK_ENV=development

# Azure Authentication — pick ONE method:

# Option 1: Access token (easiest for local dev)
#   Run: az account get-access-token --resource https://management.azure.com/ --query accessToken -o tsv
#   Then paste the value here:
# AZURE_ACCESS_TOKEN=eyJ0eXAi...

# Option 2: Service principal (for CI / long-lived containers)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
